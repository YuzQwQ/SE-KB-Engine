{
  "description": "DFD 中的数据项在数据字典中的定义方式，字段、结构、格式说明。",
  "data_dictionary": {
    "role": "为所有数据流、数据存储定义结构、类型和约束，是 DFD 的配套文档。",
    "data_item_format": {
      "fields": ["名称", "类型", "来源", "去向", "取值范围", "结构说明"],
      "example": {
        "name": "transaction_request",
        "structure": {
          "cardNumber": "String(16)",
          "password": "String(6)",
          "amount": "Decimal(10,2)",
          "timestamp": "Datetime"
        },
        "constraints": {
          "cardNumber": { "pattern": "^[0-9]{16}$" },
          "password": { "pattern": "^[0-9]{6}$" },
          "amount": { "min": 0.01, "max": 100000.00 },
          "timestamp": { "format": "date-time" }
        }
      }
    },
    "additional_examples": [
      {
        "name": "withdraw_command",
        "structure": {
          "accountId": "String(32)",
          "amount": "Decimal(10,2)",
          "deviceId": "String(32)",
          "requestId": "String(36)"
        },
        "constraints": {
          "amount": { "min": 20.00, "max": 5000.00 },
          "requestId": { "pattern": "^[a-f0-9-]{36}$" }
        },
        "dfd_mapping": {
          "flow": "withdraw_request",
          "source": "E_USER",
          "target": "P1_VALIDATE_INPUT"
        }
      }
    ],
    "relationship_to_dfd": [
      "数据流的结构必须在数据字典中定义",
      "数据存储的字段结构可源自 ERD",
      "DFD 的一致性（balance）需与数据字典联合检查"
    ]
  }
}
