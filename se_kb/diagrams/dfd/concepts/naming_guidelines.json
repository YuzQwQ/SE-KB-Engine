{
  "description": "DFD 元素命名建议与反例库：过程、数据流、数据存储、外部实体的命名风格与禁忌。",
  "process": {
    "rule": "动词 + 名词，长度 2–32，单一语言",
    "good": ["验证密码", "更新订单", "Query Inventory", "Generate Receipt"],
    "bad": ["密码", "处理", "Do", "流程1"]
  },
  "data_flow": {
    "rule": "动词短语或数据对象短语，避免空泛词",
    "good": ["request_*", "business_result", "update_order_status"],
    "bad": ["数据", "信息", "流1"]
  },
  "data_store": {
    "rule": "名词，可选后缀‘库’/‘存储’/‘Database’",
    "good": ["订单库", "账户存储", "Inventory Database"],
    "bad": ["保存订单", "处理库存"]
  },
  "external_entity": {
    "rule": "真实角色或系统名词",
    "good": ["顾客", "银行", "支付网关", "Delivery Staff"],
    "bad": ["处理支付", "更新订单"]
  },
  "language_consistency": {
    "rule": "单图内尽量使用同一语言",
    "hint": "混用超过 30% 时建议统一或标注"
  }
}