{
  "case_name": "University Course Registration",
  "description": "学生选课、容量校验、等待名单与通知",
  "requirements_text": [
    "学生查询课程并提交选课申请。",
    "系统校验课程容量与先修课条件。",
    "容量不足时加入等待名单并通知学生；成功选课写入记录。"
  ],
  "dfd_elements": {
    "external_entities": [
      { "id": "E1", "name": "Student" },
      { "id": "E2", "name": "Notification Service" }
    ],
    "processes": [
      { "id": "P1", "name": "Query Courses" },
      { "id": "P2", "name": "Validate Prerequisites" },
      { "id": "P3", "name": "Check Capacity" },
      { "id": "P4", "name": "Enroll or Waitlist" },
      { "id": "P5", "name": "Send Notification" }
    ],
    "data_stores": [
      { "id": "D1", "name": "Course Catalog" },
      { "id": "D2", "name": "Enrollment Records" },
      { "id": "D3", "name": "Waitlist Records" }
    ],
    "data_flows": [
      { "from": "Student", "to": "P1", "data": "Course Query" },
      { "from": "P1", "to": "D1", "data": "Read Courses" },
      { "from": "Student", "to": "P2", "data": "Enrollment Request" },
      { "from": "P2", "to": "P3", "data": "Prereq Validated" },
      { "from": "P3", "to": "P4", "data": "Capacity Status" },
      { "from": "P4", "to": "D2", "data": "Write Enrollment" },
      { "from": "P4", "to": "D3", "data": "Write Waitlist" },
      { "from": "P4", "to": "P5", "data": "Notify Content" },
      { "from": "P5", "to": "Notification Service", "data": "Send Message" },
      { "from": "Notification Service", "to": "Student", "data": "Notification" }
    ]
  }
}