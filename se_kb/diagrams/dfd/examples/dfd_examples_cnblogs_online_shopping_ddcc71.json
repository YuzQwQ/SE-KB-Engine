{
  "content_slug": "online_shopping",
  "case_name": "在线购物系统数据流图示例",
  "description": "一个典型的在线购物系统，用户浏览商品、下单购买，系统处理订单并更新库存，管理员管理商品信息和订单数据。",
  "requirements_text": [
    "用户可以浏览商品目录并选择商品加入购物车。",
    "用户提交订单后，系统验证库存并生成订单记录。",
    "系统扣减库存并发送订单确认信息给用户。",
    "管理员可以添加、修改或删除商品信息。",
    "管理员可以查看和导出所有订单数据。"
  ],
  "dfd_elements": {
    "external_entities": [
      {
        "id": "E1",
        "name": "用户"
      },
      {
        "id": "E2",
        "name": "管理员"
      }
    ],
    "processes": [
      {
        "id": "P1",
        "name": "浏览商品"
      },
      {
        "id": "P2",
        "name": "提交订单"
      },
      {
        "id": "P3",
        "name": "验证库存"
      },
      {
        "id": "P4",
        "name": "扣减库存"
      },
      {
        "id": "P5",
        "name": "发送确认信息"
      },
      {
        "id": "P6",
        "name": "管理商品信息"
      },
      {
        "id": "P7",
        "name": "查看订单数据"
      }
    ],
    "data_stores": [
      {
        "id": "DS1",
        "name": "商品信息库"
      },
      {
        "id": "DS2",
        "name": "订单记录库"
      },
      {
        "id": "DS3",
        "name": "库存数据"
      }
    ],
    "data_flows": [
      {
        "from": "E1",
        "to": "P1",
        "data": "商品查询请求"
      },
      {
        "from": "P1",
        "to": "DS1",
        "data": "商品目录"
      },
      {
        "from": "E1",
        "to": "P2",
        "data": "订单信息"
      },
      {
        "from": "P2",
        "to": "P3",
        "data": "订单详情"
      },
      {
        "from": "P3",
        "to": "DS3",
        "data": "库存检查请求"
      },
      {
        "from": "DS3",
        "to": "P3",
        "data": "库存状态"
      },
      {
        "from": "P3",
        "to": "DS2",
        "data": "新订单记录"
      },
      {
        "from": "P3",
        "to": "P4",
        "data": "扣减指令"
      },
      {
        "from": "P4",
        "to": "DS3",
        "data": "更新后库存"
      },
      {
        "from": "P4",
        "to": "E1",
        "data": "订单确认信息"
      },
      {
        "from": "E2",
        "to": "P6",
        "data": "商品管理指令"
      },
      {
        "from": "P6",
        "to": "DS1",
        "data": "商品信息更新"
      },
      {
        "from": "E2",
        "to": "P7",
        "data": "订单查询请求"
      },
      {
        "from": "P7",
        "to": "DS2",
        "data": "订单数据"
      }
    ]
