{
  "case_name": "ATM Balance Inquiry",
  "description": "用户在 ATM 上查询账户余额的简单查询流程",
  "requirements_text": [
    "用户插卡并输入密码进行身份验证。",
    "系统读取账户余额并在屏幕显示。",
    "若密码错误则提示错误并允许重试。"
  ],
  "dfd_elements": {
    "external_entities": [
      { "id": "E1", "name": "Customer" }
    ],
    "processes": [
      { "id": "P1", "name": "Collect Card & PIN" },
      { "id": "P2", "name": "Validate PIN" },
      { "id": "P3", "name": "Read Balance" },
      { "id": "P4", "name": "Display Result" },
      { "id": "P5", "name": "Handle Error/Retry" }
    ],
    "data_stores": [
      { "id": "D1", "name": "Account Database" }
    ],
    "data_flows": [
      { "from": "Customer", "to": "P1", "data": "Card + PIN" },
      { "from": "P1", "to": "P2", "data": "PIN Data" },
      { "from": "P2", "to": "D1", "data": "Read Account Balance" },
      { "from": "D1", "to": "P3", "data": "Balance" },
      { "from": "P3", "to": "P4", "data": "Balance Result" },
      { "from": "P2", "to": "P5", "data": "Error Info?" },
      { "from": "P5", "to": "P1", "data": "Retry Request?" },
      { "from": "P4", "to": "Customer", "data": "Display Balance" }
    ]
  }
}