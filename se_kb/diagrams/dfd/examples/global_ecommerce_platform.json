      { "id": "D11", "name": "Event Bus" },
      { "id": "D12", "name": "Analytics Warehouse" }
    ],
    "data_flows": [
      { "from": "Customer", "to": "P1", "data": "Cart + Context" },
      { "from": "P1", "to": "P2", "data": "Cart Items" },
      { "from": "P2", "to": "D4", "data": "Query Promotions" },
      { "from": "D4", "to": "P2", "data": "Promotion Info" },
      { "from": "P2", "to": "P3", "data": "Priced Items" },
