{
  "case_name": "Global E-commerce Platform",
  "description": "跨多区域的电商平台：订单、定价、风控、支付、库存、物流、结算、分析与合规",
  "requirements_text": [
    "支持购物车与多币种定价、跨区域税费计算。",
    "订单创建前进行风控预检，支付后进行库存分配与发货。",
    "异步支付回调更新订单状态，触发通知与物流创建。",
    "支持退货与退款，纳税开票与对账结算。",
    "事件总线汇聚业务事件进入分析仓库，生成报表与监控。",
    "全链路审计与合规记录，包含敏感数据脱敏。"
  ],
  "dfd_elements": {
    "external_entities": [
      { "id": "E1", "name": "Customer" },
      { "id": "E2", "name": "Merchant" },
      { "id": "E3", "name": "Payment Gateway" },
      { "id": "E4", "name": "Logistics Provider" },
      { "id": "E5", "name": "Tax Bureau" },
      { "id": "E6", "name": "Marketing Platform" },
      { "id": "E7", "name": "Map Service" },
      { "id": "E8", "name": "Fraud Service" },
      { "id": "E9", "name": "Notification Service" }
    ],
    "processes": [
      { "id": "P1", "name": "Collect Cart & Customer Context" },
      { "id": "P2", "name": "Price Calculation & Promotion" },
      { "id": "P3", "name": "Fraud Pre-check" },
      { "id": "P4", "name": "Create Order" },
      { "id": "P5", "name": "Initiate Payment" },
      { "id": "P6", "name": "Handle Payment Callback" },
      { "id": "P7", "name": "Allocate Inventory & Reserve" },
      { "id": "P8", "name": "Warehouse Picking & Packing" },
      { "id": "P9", "name": "Create Shipment" },
      { "id": "P10", "name": "Notify Customer & Merchant" },
      { "id": "P11", "name": "Tax Calculation & Invoice" },
      { "id": "P12", "name": "Reconciliation & Settlement" },
      { "id": "P13", "name": "Returns & Refund Processing" },
      { "id": "P14", "name": "Customer Support & Case Management" },
      { "id": "P15", "name": "Event Stream to Analytics" },
      { "id": "P16", "name": "Audit & Compliance Logging" }
    ],
    "data_stores": [
      { "id": "D1", "name": "Order Database" },
      { "id": "D2", "name": "Inventory Database" },
      { "id": "D3", "name": "Customer Database" },
      { "id": "D4", "name": "Promotion Database" },
      { "id": "D5", "name": "Fraud Results" },
      { "id": "D6", "name": "Payment Records" },
      { "id": "D7", "name": "Shipment Database" },
      { "id": "D8", "name": "Invoice & Tax Records" },
