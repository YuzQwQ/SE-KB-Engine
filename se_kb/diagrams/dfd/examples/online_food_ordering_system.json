{
  "case_name": "Online Food Ordering System",
  "description": "用户下单、支付、餐厅接单及配送的典型外卖业务",
  "requirements_text": [
    "用户可以浏览菜单并提交订单。",
    "系统在用户下单后需要创建订单，并通知餐厅处理。",
    "用户需要通过第三方支付平台完成支付。",
    "支付成功后系统将订单状态更新为已支付。",
    "餐厅准备完餐食后通知系统开始配送。",
    "配送员在完成配送后更新订单状态为已送达。"
  ],
  "dfd_elements": {
    "external_entities": [
      { "id": "E1", "name": "Customer" },
      { "id": "E2", "name": "Restaurant" },
      { "id": "E3", "name": "Delivery Staff" },
      { "id": "E4", "name": "Payment Gateway" }
    ],
    "processes": [
      { "id": "P1", "name": "Browse Menu & Create Order" },
      { "id": "P2", "name": "Process Payment" },
      { "id": "P3", "name": "Update Order Status" },
      { "id": "P4", "name": "Notify Restaurant" },
      { "id": "P5", "name": "Handle Delivery Status" }
    ],
    "data_stores": [
      { "id": "D1", "name": "Menu Database" },
      { "id": "D2", "name": "Order Database" }
    ],
    "data_flows": [
      { "from": "Customer", "to": "P1", "data": "Order Request" },
      { "from": "P1", "to": "D2", "data": "New Order" },
      { "from": "P1", "to": "E2", "data": "Order Notification" },

      { "from": "Customer", "to": "P2", "data": "Payment Info" },
      { "from": "P2", "to": "Payment Gateway", "data": "Payment Request" },
      { "from": "Payment Gateway", "to": "P2", "data": "Payment Result" },
      { "from": "P2", "to": "P3", "data": "Payment Success Notice" },

      { "from": "P3", "to": "D2", "data": "Update Order Status" },

      { "from": "Restaurant", "to": "P5", "data": "Food Ready Notice" },
      { "from": "P5", "to": "Delivery Staff", "data": "Delivery Request" },
      { "from": "Delivery Staff", "to": "P5", "data": "Delivered Notice" },
      { "from": "P5", "to": "D2", "data": "Update Delivery Status" }
    ]
  }
}
