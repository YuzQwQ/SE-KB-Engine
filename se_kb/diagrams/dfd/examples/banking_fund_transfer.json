{
  "case_name": "Banking Fund Transfer",
  "description": "账户间转账：身份验证、余额校验、交易入账与回执",
  "requirements_text": [
    "用户发起转账请求并输入收款账户与金额。",
    "系统验证用户身份与风险限额，检查余额充足。",
    "系统生成交易并写入流水，返回回执给用户。"
  ],
  "dfd_elements": {
    "external_entities": [
      { "id": "E1", "name": "Customer" }
    ],
    "processes": [
      { "id": "P1", "name": "Collect Transfer Request" },
      { "id": "P2", "name": "Validate Identity & Limits" },
      { "id": "P3", "name": "Check Balance" },
      { "id": "P4", "name": "Create Transaction" },
      { "id": "P5", "name": "Generate Receipt" }
    ],
    "data_stores": [
      { "id": "D1", "name": "Account DB" },
      { "id": "D2", "name": "Transaction Ledger" }
    ],
    "data_flows": [
      { "from": "Customer", "to": "P1", "data": "Transfer Details" },
      { "from": "P2", "to": "D1", "data": "Read Identity & Limits" },
      { "from": "P3", "to": "D1", "data": "Read Balance" },
      { "from": "P2", "to": "P3", "data": "Validation Result" },
      { "from": "P3", "to": "P4", "data": "Balance OK" },
      { "from": "P4", "to": "D2", "data": "Write Transaction" },
      { "from": "P4", "to": "P5", "data": "Transaction Info" },
      { "from": "P5", "to": "Customer", "data": "Receipt" }
    ]
  }
}