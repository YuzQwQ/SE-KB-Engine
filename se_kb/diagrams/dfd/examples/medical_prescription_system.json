{
  "case_name": "Electronic Prescription System",
  "description": "医生开具电子处方，药房审核发药，医保结算与通知",
  "requirements_text": [
    "医生录入诊断并开具处方。",
    "药房审核库存与处方合法性，准备发药。",
    "系统与医保结算并通知患者取药。"
  ],
  "dfd_elements": {
    "external_entities": [
      { "id": "E1", "name": "Doctor" },
      { "id": "E2", "name": "Pharmacy" },
      { "id": "E3", "name": "Insurance Center" },
      { "id": "E4", "name": "Patient" }
    ],
    "processes": [
      { "id": "P1", "name": "Create Prescription" },
      { "id": "P2", "name": "Pharmacy Review" },
      { "id": "P3", "name": "Prepare Medication" },
      { "id": "P4", "name": "Insurance Settlement" },
      { "id": "P5", "name": "Notify Patient" }
    ],
    "data_stores": [
      { "id": "D1", "name": "Prescription DB" },
      { "id": "D2", "name": "Medication Inventory" },
      { "id": "D3", "name": "Settlement Records" }
    ],
    "data_flows": [
      { "from": "Doctor", "to": "P1", "data": "Prescription Data" },
      { "from": "P1", "to": "D1", "data": "Store Prescription" },
      { "from": "Pharmacy", "to": "P2", "data": "Review Request" },
      { "from": "P2", "to": "D2", "data": "Check Inventory" },
      { "from": "P2", "to": "P3", "data": "Approved Items" },
      { "from": "P3", "to": "D2", "data": "Update Inventory" },
      { "from": "P3", "to": "P4", "data": "Settlement Request" },
      { "from": "P4", "to": "Insurance Center", "data": "Insurance Claim" },
      { "from": "Insurance Center", "to": "P4", "data": "Settlement Result" },
      { "from": "P4", "to": "D3", "data": "Store Settlement" },
      { "from": "P4", "to": "P5", "data": "Notify Content" },
      { "from": "P5", "to": "Patient", "data": "Pickup Notification" }
    ]
  }
}