        },
        {
          "id": "workflow_approval",
          "name": "工作流审批模板",
          "dfd_level": 2,
          "pattern_type": "composite",
          "structure": {
            "nodes": {
              "processes": [
                {
                  "id": "P1_RECEIVE_REQUEST",
                  "name": "接收请求",
                  "role": "接收申请或业务请求"
                },
                {
                  "id": "P2_PRECHECK",
                  "name": "初审",
                  "role": "形式/完整性审查"
                },
                {
                  "id": "P3_REVIEW",
                  "name": "复审或业务审核",
                  "role": "实质性业务审核"
                },
                {
                  "id": "P4_DECIDE",
                  "name": "批准/驳回",
                  "role": "做出最终处理决定并通知"
                }
              ]
            }
          },
          "applicable_scenarios": [
            "教材购销系统中缺书申请、采购审批流程",
            "贷款审批、报销审批等多环节业务"
          ],
          "notes": [
            "可与状态图配合，状态图侧重状态迁移，DFD 侧重数据与处理。",
