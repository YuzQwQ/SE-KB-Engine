{
  "content_slug": "dfd_basic_template_library",
  "description": "DFD 模板库",
  "categories": [
    {
      "id": "top_level",
      "name": "顶层上下文图模板",
      "templates": [
        {
          "id": "context_diagram_single_process",
          "name": "单处理上下文图模板",
          "dfd_level": 0,
          "pattern_type": "context",
          "placeholders": {
            "processes": [
              "P1_系统名称"
            ],
            "external_entities": [
              "E_源点/终点名称"
            ]
          },
          "structure": {
            "nodes": {
              "P1_系统名称": "圆角矩形，代表整个系统",
              "E_源点/终点名称": "正方形，代表外部实体"
            },
            "data_flows": [
              {
                "from": "E_源点/终点名称",
                "to": "P1_系统名称",
                "label": "输入数据流"
              },
              {
                "from": "P1_系统名称",
                "to": "E_源点/终点名称",
                "label": "输出数据流"
              }
            ]
          },
          "applicable_scenarios": [
            "任何信息系统初始建模阶段",
            "与用户沟通系统边界时",
            "需求分析初期抽象系统功能"
          ],
          "notes": [
            "顶层图仅包含一个处理和外部实体",
            "不体现内部处理、数据存储或条件逻辑",
            "外部实体命名应使用业务角色名称（如采购员、仓库管理员）"
          ]
        }
      ]
    },
    {
      "id": "decomposition",
      "name": "功能分解结构模板",
      "templates": [
        {
          "id": "functional_decomposition_two_main_processes",
          "name": "双主功能分解模板",
          "dfd_level": 1,
          "pattern_type": "functional_decomposition",
          "placeholders": {
            "processes": [
              "P1_主功能1",
              "P2_主功能2"
            ],
            "external_entities": [
              "E_源点",
              "E_终点"
            ],
            "data_stores": [
              "D_持久化数据存储"
            ]
          },
          "structure": {
            "nodes": {
              "P1_主功能1": "圆角矩形，代表核心处理1",
              "P2_主功能2": "圆角矩形，代表核心处理2",
              "D_持久化数据存储": "开口矩形，代表长期存储",
              "E_源点": "正方形",
              "E_终点": "正方形"
            },
            "data_flows": [
              {
                "from": "E_源点",
                "to": "P1_主功能1",
                "label": "输入事务/请求"
              },
              {
                "from": "P1_主功能1",
                "to": "D_持久化数据存储",
                "label": "更新数据"
              },
              {
                "from": "D_持久化数据存储",
                "to": "P2_主功能2",
                "label": "查询数据"
              },
              {
                "from": "P2_主功能2",
                "to": "E_终点",
                "label": "输出报告/结果"
              }
            ]
          },
          "applicable_scenarios": [
            "订单/事务处理系统（如工厂订货系统）",
            "需分离实时处理与批处理的系统",
            "有明确数据持久化需求的业务系统"
          ],
          "notes": [
            "分解应基于时间或逻辑分离（如事务处理 vs 报表生成）",
            "避免分解到实现细节（如打印格式、数据库查询语句）",
            "编号规则：父级P1分解为P1.1, P1.2..."
          ]
        },
        {
          "id": "functional_decomposition_three_step_process",
          "name": "三步事务处理分解模板",
          "dfd_level": 1,
          "pattern_type": "functional_decomposition",
          "placeholders": {
            "processes": [
              "P1_接收",
              "P2_更新",
              "P3_处理"
            ],
            "data_stores": [
              "D_状态存储"
            ]
          },
          "structure": {
            "nodes": {
              "P1_接收": "圆角矩形",
              "P2_更新": "圆角矩形",
              "P3_处理": "圆角矩形",
              "D_状态存储": "开口矩形"
            },
            "data_flows": [
              {
                "from": "E_源点",
                "to": "P1_接收",
                "label": "事务数据"
              },
              {
                "from": "P1_接收",
                "to": "D_状态存储",
                "label": "请求更新"
              },
              {
                "from": "D_状态存储",
                "to": "P2_更新",
                "label": "当前状态"
              },
              {
                "from": "P2_更新",
                "to": "D_状态存储",
                "label": "更新后状态"
              },
              {
                "from": "D_状态存储",
                "to": "P3_处理",
                "label": "触发条件"
              },
              {
                "from": "P3_处理",
                "to": "D_状态存储",
                "label": "生成动作"
              }
            ]
          },
          "applicable_scenarios": [
            "库存管理、订单触发、状态变更类系统",
            "基于阈值触发业务动作的场景（如库存低于临界值）",
            "需要分离输入、变更、响应逻辑的流程"
          ],
          "notes": [
            "每个步骤应为单一职责，避免复合功能",
            "P3_处理应基于数据存储中的条件判断，而非流程控制",
            "命名应使用具体动词+宾语（如'更新库存清单'而非'处理事务'）"
          ]
        }
      ]
    },
    {
      "id": "data_store_interaction",
      "name": "数据存储交互模板",
      "templates": [
        {
          "id": "data_store_read_write_pattern",
          "name": "数据存储读写交互模板",
          "dfd_level": 1,
          "pattern_type": "data_store_interaction",
          "placeholders": {
            "processes": [
              "P_读取",
              "P_写入"
            ],
            "data_stores": [
              "D_核心数据存储"
            ]
          },
          "structure": {
            "nodes": {
              "P_读取": "圆角矩形",
              "P_写入": "圆角矩形",
              "D_核心数据存储": "开口矩形"
            },
            "data_flows": [
              {
                "from": "P_写入",
                "to": "D_核心数据存储",
                "label": "更新数据"
              },
              {
                "from": "D_核心数据存储",
                "to": "P_读取",
                "label": "查询数据"
              }
            ]
          },
          "applicable_scenarios": [
            "任何需要持久化状态的系统",
            "读写分离的业务场景（如库存更新与报表生成）",
            "多处理共享同一数据源的系统"
          ],
          "notes": [
            "数据存储代表静止状态的数据，数据流代表运动中的数据",
            "同一数据存储可被多个处理读写，但需保持命名一致性",
            "避免在DFD中体现文件打开/关闭等内务操作"
          ]
        }
      ]
    },
    {
      "id": "error_handling",
      "name": "错误和超时处理模板",
      "templates": [
        {
          "id": "error_handling_excluded",
          "name": "错误处理排除模板",
          "dfd_level": 0,
          "pattern_type": "error_handling",
          "placeholders": {
            "processes": [],
            "external_entities": []
          },
          "structure": {
            "nodes": {},
            "data_flows": []
          },
          "applicable_scenarios": [
            "标准DFD建模规范场景",
            "需求分析与逻辑建模阶段"
          ],
          "notes": [
            "DFD不包含错误处理、异常流程或重试机制",
            "不体现超时、网络失败、权限拒绝等异常路径",
            "错误处理应在后续的状态图或流程图中建模",
            "DFD聚焦于'做什么'，而非'如何处理失败'"
          ]
        }
      ]
    }
  ]
}