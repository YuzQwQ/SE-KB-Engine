{
  "content_slug": "dfd_template_library",
  "description": "DFD 模板库",
  "categories": [
    {
      "id": "top_level",
      "name": "顶层上下文图",
      "templates": [
        {
          "id": "context_diagram_template",
          "name": "标准上下文图模板",
          "dfd_level": 0,
          "pattern_type": "context",
          "placeholders": {
            "processes": [
              "P1_System"
            ],
            "external_entities": [
              "E_User",
              "E_External_System"
            ]
          },
          "structure": {
            "nodes": {
              "P1_System": "系统核心处理过程",
              "E_User": "外部用户或角色",
              "E_External_System": "外部系统或数据源"
            },
            "data_flows": [
              {
                "from": "E_User",
                "to": "P1_System",
                "label": "输入请求"
              },
              {
                "from": "P1_System",
                "to": "E_User",
                "label": "输出响应"
              },
              {
                "from": "E_External_System",
                "to": "P1_System",
                "label": "外部数据"
              },
              {
                "from": "P1_System",
                "to": "E_External_System",
                "label": "数据同步"
              }
            ]
          },
          "applicable_scenarios": [
            "系统级需求建模",
            "项目启动阶段的高层视图设计",
            "与利益相关者沟通系统边界"
          ],
          "notes": [
            "顶层图仅包含一个处理过程，代表整个系统",
            "外部实体应为系统边界外的主动参与者",
            "避免在Level-0中出现数据存储"
          ]
        }
      ]
    },
    {
      "id": "decomposition",
      "name": "功能分解结构",
      "templates": [
        {
          "id": "functional_decomposition_template",
          "name": "三层功能分解模板",
          "dfd_level": 1,
          "pattern_type": "functional_decomposition",
          "placeholders": {
            "processes": [
              "P1_Validate",
              "P2_Process",
              "P3_Generate"
            ],
            "external_entities": []
          },
          "structure": {
            "nodes": {
              "P1_Validate": "输入验证与过滤",
              "P2_Process": "核心业务处理",
              "P3_Generate": "结果生成与输出"
            },
            "data_flows": [
              {
                "from": "E_User",
                "to": "P1_Validate",
                "label": "原始请求"
              },
              {
                "from": "P1_Validate",
                "to": "P2_Process",
                "label": "有效数据"
              },
              {
                "from": "P2_Process",
                "to": "P3_Generate",
                "label": "处理结果"
              },
              {
                "from": "P3_Generate",
                "to": "E_User",
                "label": "最终响应"
              }
            ]
          },
          "applicable_scenarios": [
            "业务流程清晰的系统",
            "需要分层解耦的模块化设计",
            "从上下文图展开到一级分解"
          ],
          "notes": [
            "每个子过程应具有单一职责",
            "数据流应保持端到端一致性",
            "避免过程间直接通信，必须通过数据流"
          ]
        }
      ]
    },
    {
      "id": "data_store_interaction",
      "name": "数据存储交互模板",
      "templates": [
        {
          "id": "crud_data_store_template",
          "name": "CRUD 数据存储交互模板",
          "dfd_level": 1,
          "pattern_type": "data_store_interaction",
          "placeholders": {
            "processes": [
              "P1_Create",
              "P2_Read",
              "P3_Update",
              "P4_Delete"
            ],
            "external_entities": [
              "E_User"
            ]
          },
          "structure": {
            "nodes": {
              "P1_Create": "创建记录",
              "P2_Read": "查询记录",
              "P3_Update": "更新记录",
              "P4_Delete": "删除记录",
              "DS_DataStore": "数据存储"
            },
            "data_flows": [
              {
                "from": "E_User",
                "to": "P1_Create",
                "label": "创建请求"
              },
              {
                "from": "P1_Create",
                "to": "DS_DataStore",
                "label": "新数据"
              },
              {
                "from": "DS_DataStore",
                "to": "P2_Read",
                "label": "存储数据"
              },
              {
                "from": "P2_Read",
                "to": "E_User",
                "label": "查询结果"
              },
              {
                "from": "E_User",
                "to": "P3_Update",
                "label": "更新指令"
              },
              {
                "from": "P3_Update",
                "to": "DS_DataStore",
                "label": "更新数据"
              },
              {
                "from": "E_User",
                "to": "P4_Delete",
                "label": "删除指令"
              },
              {
                "from": "P4_Delete",
                "to": "DS_DataStore",
                "label": "删除标记"
              }
            ]
          },
          "applicable_scenarios": [
            "数据库驱动的业务系统",
            "需要明确CRUD操作分离的场景",
            "数据持久化层建模"
          ],
          "notes": [
            "数据存储必须通过过程访问，不能直接连接外部实体",
            "每个CRUD操作应独立为过程，便于维护",
            "建议使用DS_前缀标识数据存储节点"
          ]
        }
      ]
    },
    {
      "id": "error_handling",
      "name": "错误和超时处理模板",
      "templates": [
        {
          "id": "error_timeout_handling_template",
          "name": "错误与超时处理模板",
          "dfd_level": 1,
          "pattern_type": "error_handling",
          "placeholders": {
            "processes": [
              "P1_Main",
              "P2_ErrorLog",
              "P3_TimeoutFallback"
            ],
            "external_entities": [
              "E_User",
              "E_Admin"
            ]
          },
          "structure": {
            "nodes": {
              "P1_Main": "主处理流程",
              "P2_ErrorLog": "错误日志记录",
              "P3_TimeoutFallback": "超时降级处理",
              "DS_ErrorLog": "错误日志存储"
            },
            "data_flows": [
              {
                "from": "E_User",
                "to": "P1_Main",
                "label": "请求"
              },
              {
                "from": "P1_Main",
                "to": "E_User",
                "label": "成功响应"
              },
              {
                "from": "P1_Main",
                "to": "P2_ErrorLog",
                "label": "错误信息"
              },
              {
                "from": "P2_ErrorLog",
                "to": "DS_ErrorLog",
                "label": "记录错误"
              },
              {
                "from": "P2_ErrorLog",
                "to": "E_Admin",
                "label": "告警通知"
              },
              {
                "from": "P1_Main",
                "to": "P3_TimeoutFallback",
                "label": "超时信号"
              },
              {
                "from": "P3_TimeoutFallback",
                "to": "E_User",
                "label": "降级响应"
              }
            ]
          },
          "applicable_scenarios": [
            "高可用系统设计",
            "需要容错与降级机制的场景",
            "金融、医疗等强可靠性系统"
          ],
          "notes": [
            "错误路径应与主路径分离，避免污染正常流程",
            "超时处理应有明确的触发条件和降级策略",
            "错误日志应记录时间、类型、上下文，供运维分析"
          ]
        }
      ]
    }
  ]
}