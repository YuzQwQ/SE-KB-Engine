{
  "content_slug": "context_diagram_and_decomposition",
  "description": "DFD 模板库",
  "categories": [
    {
      "id": "top_level",
      "name": "顶层上下文图",
      "templates": [
        {
          "id": "context_diagram_template",
          "name": "系统上下文图模板",
          "dfd_level": 0,
          "pattern_type": "context",
          "placeholders": {
            "processes": [
              "P1_System"
            ],
            "external_entities": [
              "E_User",
              "E_External_System",
              "E_Device"
            ]
          },
          "structure": {
            "nodes": {
              "P1_System": {
                "type": "process",
                "label": "系统名称"
              }
            },
            "data_flows": [
              {
                "from": "E_User",
                "to": "P1_System",
                "label": "输入数据"
              },
              {
                "from": "P1_System",
                "to": "E_User",
                "label": "输出数据"
              },
              {
                "from": "E_External_System",
                "to": "P1_System",
                "label": "外部数据"
              },
              {
                "from": "P1_System",
                "to": "E_External_System",
                "label": "反馈数据"
              }
            ]
          },
          "applicable_scenarios": [
            "系统边界定义",
            "初始需求分析",
            "与外部系统交互建模"
          ],
          "notes": [
            "顶层图仅包含一个核心处理过程和外部实体",
            "不包含数据存储，仅展示系统与外界的数据交互"
          ]
        }
      ]
    },
    {
      "id": "decomposition",
      "name": "功能分解结构",
      "templates": [
        {
          "id": "functional_decomposition_template",
          "name": "功能分解模板",
          "dfd_level": 1,
          "pattern_type": "functional_decomposition",
          "placeholders": {
            "processes": [
              "P1_Validate_User",
              "P2_Process_Data",
              "P3_Generate_Report"
            ],
            "external_entities": [
              "E_User",
              "E_External_System"
            ],
            "data_stores": [
              "D_User_DB",
              "D_Transaction_Log"
            ]
          },
          "structure": {
            "nodes": {
              "P1_Validate_User": {
                "type": "process",
                "label": "验证用户身份"
              },
              "P2_Process_Data": {
                "type": "process",
                "label": "处理业务数据"
              },
              "P3_Generate_Report": {
                "type": "process",
                "label": "生成报告"
              },
              "D_User_DB": {
                "type": "data_store",
                "label": "用户数据库"
              },
              "D_Transaction_Log": {
                "type": "data_store",
                "label": "交易日志"
              }
            },
            "data_flows": [
              {
                "from": "E_User",
                "to": "P1_Validate_User",
                "label": "登录凭证"
              },
              {
                "from": "P1_Validate_User",
                "to": "D_User_DB",
                "label": "查询请求"
              },
              {
                "from": "D_User_DB",
                "to": "P1_Validate_User",
                "label": "用户信息"
              },
              {
                "from": "P1_Validate_User",
                "to": "P2_Process_Data",
                "label": "认证通过信号"
              },
              {
                "from": "P2_Process_Data",
                "to": "D_Transaction_Log",
                "label": "记录事务"
              },
              {
                "from": "P2_Process_Data",
                "to": "P3_Generate_Report",
                "label": "处理后数据"
              },
              {
                "from": "P3_Generate_Report",
                "to": "E_User",
                "label": "生成报告"
              }
            ]
          },
          "applicable_scenarios": [
            "业务流程细化",
            "模块化系统设计",
            "从顶层图向下分解"
          ],
          "notes": [
            "每个子过程应有明确输入输出",
            "数据存储必须连接至少一个读取和一个写入过程"
          ]
        }
      ]
    },
    {
      "id": "data_store_interaction",
      "name": "数据存储交互模板",
      "templates": [
        {
          "id": "data_store_interaction_template",
          "name": "数据存储读写交互模板",
          "dfd_level": 1,
          "pattern_type": "data_store_interaction",
          "placeholders": {
            "processes": [
              "P_Read_Data",
              "P_Write_Data",
              "P_Update_Data"
            ],
            "data_stores": [
              "D_Master_Data",
              "D_Cache"
            ]
          },
          "structure": {
            "nodes": {
              "P_Read_Data": {
                "type": "process",
                "label": "读取数据"
              },
              "P_Write_Data": {
                "type": "process",
                "label": "写入数据"
              },
              "P_Update_Data": {
                "type": "process",
                "label": "更新数据"
              },
              "D_Master_Data": {
                "type": "data_store",
                "label": "主数据存储"
              },
              "D_Cache": {
                "type": "data_store",
                "label": "缓存存储"
              }
            },
            "data_flows": [
              {
                "from": "P_Read_Data",
                "to": "D_Master_Data",
                "label": "读取请求"
              },
              {
                "from": "D_Master_Data",
                "to": "P_Read_Data",
                "label": "数据响应"
              },
              {
                "from": "P_Write_Data",
                "to": "D_Master_Data",
                "label": "写入数据"
              },
              {
                "from": "P_Update_Data",
                "to": "D_Master_Data",
                "label": "更新指令"
              },
              {
                "from": "D_Master_Data",
                "to": "D_Cache",
                "label": "同步缓存"
              },
              {
                "from": "D_Cache",
                "to": "P_Read_Data",
                "label": "缓存数据"
              }
            ]
          },
          "applicable_scenarios": [
            "数据库读写建模",
            "缓存机制设计",
            "数据持久化流程"
          ],
          "notes": [
            "每个数据存储必须有至少一个写入和一个读取过程",
            "避免数据存储直接连接外部实体"
          ]
        }
      ]
    },
    {
      "id": "error_handling",
      "name": "错误和超时处理模板",
      "templates": [
        {
          "id": "error_handling_template",
          "name": "错误与超时处理模板",
          "dfd_level": 1,
          "pattern_type": "error_handling",
          "placeholders": {
            "processes": [
              "P_Process_Request",
              "P_Handle_Error",
              "P_Log_Failure"
            ],
            "external_entities": [
              "E_User",
              "E_System_Admin"
            ],
            "data_stores": [
              "D_Error_Log"
            ]
          },
          "structure": {
            "nodes": {
              "P_Process_Request": {
                "type": "process",
                "label": "处理请求"
              },
              "P_Handle_Error": {
                "type": "process",
                "label": "处理错误"
              },
              "P_Log_Failure": {
                "type": "process",
                "label": "记录失败"
              },
              "D_Error_Log": {
                "type": "data_store",
                "label": "错误日志"
              }
            },
            "data_flows": [
              {
                "from": "E_User",
                "to": "P_Process_Request",
                "label": "请求数据"
              },
              {
                "from": "P_Process_Request",
                "to": "E_User",
                "label": "成功响应"
              },
              {
                "from": "P_Process_Request",
                "to": "P_Handle_Error",
                "label": "错误信号"
              },
              {
                "from": "P_Handle_Error",
                "to": "E_User",
                "label": "错误提示"
              },
              {
                "from": "P_Handle_Error",
                "to": "P_Log_Failure",
                "label": "错误详情"
              },
              {
                "from": "P_Log_Failure",
                "to": "D_Error_Log",
                "label": "写入日志"
              },
              {
                "from": "P_Handle_Error",
                "to": "E_System_Admin",
                "label": "告警通知"
              }
            ]
          },
          "applicable_scenarios": [
            "系统容错设计",
            "异常流程建模",
            "监控与告警机制"
          ],
          "notes": [
            "错误路径应独立于主数据流",
            "错误处理过程不应阻塞主流程的正常输出",
            "建议包含日志记录和管理员通知路径"
          ]
        }
      ]
    }
  ]
}