{
  "content_slug": "erp_migration_rules",
  "rules": [
    {
      "rule_id": "rule_01",
      "type": "约束规则",
      "condition": "企业进行ERP迁移时",
      "action": "必须确保数据的准确性，避免迁移冗余、陈旧、无效或过时的数据",
      "priority": 1
    },
    {
      "rule_id": "rule_02",
      "type": "约束规则",
      "condition": "在ERP迁移过程中",
      "action": "不得全盘复制所有旧系统数据，必须精准筛选需迁移的数据以防止混乱或错误",
      "priority": 1
    },
    {
      "rule_id": "rule_03",
      "type": "约束规则",
      "condition": "企业选择ERP实施合作伙伴时",
      "action": "必须评估供应商是否通晓最新的数据合规标准和行业法规要求",
      "priority": 1
    },
    {
      "rule_id": "rule_04",
      "type": "约束规则",
      "condition": "实施ERP数据迁移时",
      "action": "必须明确各类数据的负责人，并设立专人监管合规事宜",
      "priority": 1
    },
    {
      "rule_id": "rule_05",
      "type": "条件规则",
      "condition": "如果旧ERP系统定制化程度高",
      "action": "则ERP迁移的时间周期越长，复杂性越高，需提前规划资源与时间",
      "priority": 2
    },
    {
      "rule_id": "rule_06",
      "type": "条件规则",
      "condition": "如果企业选择迁移至ERP云",
      "action": "则无需部署和维护本地硬件，所有修复、升级和维护由供应商负责，企业只需支付固定费用",
      "priority": 2
    },
    {
      "rule_id": "rule_07",
      "type": "条件规则",
      "condition": "如果数据质量差（存在冗余、错误或不一致）",
      "action": "则会导致后续流程延迟、信息检索效率下降和洞察质量削弱",
      "priority": 2
    },
    {
      "rule_id": "rule_08",
      "type": "条件规则",
      "condition": "如果员工未做好变更准备",
      "action": "则可能导致迁移阻力增大、系统使用率降低和项目停滞",
      "priority": 2
    },
    {
      "rule_id": "rule_09",
      "type": "优先级规则",
      "condition": "在ERP迁移过程中",
      "action": "数据治理框架的建立优先于数据映射和清洗工作",
      "priority": 1
    },
    {
      "rule_id": "rule_10",
      "type": "优先级规则",
      "condition": "在ERP迁移过程中",
      "action": "利益相关方的早期参与和持续沟通优先于技术实施细节",
      "priority": 1
    },
    {
      "rule_id": "rule_11",
      "type": "优先级规则",
      "condition": "在ERP迁移过程中",
      "action": "制定全面的迁移项目计划优先于执行数据迁移操作",
      "priority": 1
    },
    {
      "rule_id": "rule_12",
      "type": "优先级规则",
      "condition": "在ERP迁移过程中",
      "action": "严格测试与验证必须在大规模迁移前完成，优先于全面部署",
      "priority": 1
    },
    {
      "rule_id": "rule_13",
      "type": "条件规则",
      "condition": "如果企业采用clean core战略",
      "action": "则可降低系统复杂性、加速版本更新并轻松集成新技术",
      "priority": 2
    },
    {
      "rule_id": "rule_14",
      "type": "条件规则",
      "condition": "如果进行云迁移",
      "action": "应分阶段实施，按部门、员工组或地区逐步推进，每个阶段需闭环后再进入下一阶段",
      "priority": 2
    }
  ],
