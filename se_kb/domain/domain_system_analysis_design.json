{
  "content_slug": "system_analysis_design",
  "domain_id": "system_analysis_design",
  "name": "系统分析与设计",
  "description": "系统分析与设计是信息系统开发的核心领域，涵盖从需求识别、建模、可行性分析到系统设计与实现的全过程，强调结构化与面向对象方法的应用，以及项目管理与生命周期控制。",
  "terms": [
    {
      "term": "系统分析",
      "definition": "理解并详细说明系统应该做什么，聚焦于需求识别与业务问题建模。",
      "examples": [
        "分析客户订购流程",
        "识别财务部门的数据需求"
      ]
    },
    {
      "term": "系统设计",
      "definition": "详细说明系统的组成结构、数据组织、输入输出和实现方式，将需求转化为可实施的技术方案。",
      "examples": [
        "设计数据库表结构",
        "定义用户界面交互流程"
      ]
    },
    {
      "term": "信息系统",
      "definition": "对信息进行收集、处理、存储并输出所需信息的一组相互关联的部件的集合。",
      "examples": [
        "ERP系统",
        "客户关系管理系统(CRM)"
      ]
    },
    {
      "term": "事务处理系统(TPS)",
      "definition": "用于处理日常业务事务的系统，如订单录入、工资计算等。",
      "examples": [
        "销售点系统(POS)",
        "银行交易系统"
      ]
    },
    {
      "term": "管理信息系统(MIS)",
      "definition": "为中层管理者提供结构化报告和数据分析支持的信息系统。",
      "examples": [
        "月度销售报表系统",
        "库存监控系统"
      ]
    },
    {
      "term": "决策支持系统(DSS)",
      "definition": "支持非结构化或半结构化决策过程的信息系统，常结合模型与数据分析。",
      "examples": [
        "销售预测模型",
        "资源配置优化工具"
      ]
    },
    {
      "term": "系统边界",
      "definition": "系统与外部环境之间输入输出所通过的分界，用于界定系统范围。",
      "examples": [
        "用户输入为系统边界输入",
        "报表输出为系统边界输出"
      ]
    },
    {
      "term": "自动化边界",
      "definition": "系统内部自动处理与人工干预之间的分界。",
      "examples": [
        "自动审批流程 vs 人工审核环节"
      ]
    },
    {
      "term": "事件驱动",
      "definition": "系统的所有处理过程由外部或内部事件触发，是需求建模的核心机制。",
      "examples": [
        "用户点击提交按钮触发订单创建",
        "定时任务触发月结"
      ]
    },
    {
      "term": "外部事件",
      "definition": "由外部实体或参与者触发的系统事件，如用户操作或外部系统调用。",
      "examples": [
        "客户在线下单",
        "供应商发货通知"
      ]
    },
    {
      "term": "内部事件",
      "definition": "由系统内部定时器或状态变化触发的事件，也称临时事件。",
      "examples": [
        "每日凌晨自动备份数据库",
        "库存低于阈值触发补货提醒"
      ]
    },
    {
      "term": "状态事件",
      "definition": "系统内部状态发生变化时引发的事件，需系统响应处理。",
      "examples": [
        "订单状态从‘待支付’变为‘已支付’",
        "用户登录超时"
      ]
    },
    {
      "term": "数据流图(DFD)",
      "definition": "图形化建模工具，展示系统的输入、输出、处理过程和数据存储。",
      "examples": [
        "订单处理DFD",
        "员工考勤DFD"
      ]
    },
    {
      "term": "类图",
      "definition": "面向对象建模中描述系统中类、属性、方法及类间关系的图形工具。",
      "examples": [
        "用户类与订单类关联图",
        "商品类与库存类关系图"
      ]
    },
    {
      "term": "用例图",
      "definition": "描述系统参与者与系统功能（用例）之间交互的模型，用于需求捕获。",
      "examples": [
        "客户下单用例",
        "管理员审核用例"
      ]
    },
    {
      "term": "结构化方法",
      "definition": "以过程和数据为核心，通过DFD、ER图、结构图等工具进行系统分析与设计的传统方法。",
      "examples": [
        "使用DFD建模采购流程",
        "用ER图设计数据库"
      ]
    },
    {
      "term": "面向对象方法",
      "definition": "将系统视为相互交互的对象集合，通过类、对象、消息传递进行建模的方法。",
      "examples": [
        "使用UML类图设计电商系统",
        "通过顺序图描述支付流程"
      ]
    },
    {
      "term": "可行性分析",
      "definition": "评估项目在经济、技术、组织和进度方面的可实施性。",
      "examples": [
        "成本收益分析",
        "开发团队技能评估"
      ]
    },
    {
      "term": "JAD会议",
      "definition": "联合应用设计会议，通过集中式研讨会快速收集用户需求与达成共识。",
      "examples": [
        "组织销售、财务、IT三方召开JAD会议定义报销流程"
      ]
    },
    {
      "term": "原型化开发",
      "definition": "通过快速构建系统原型，让用户参与反馈，逐步完善需求的方法。",
      "examples": [
        "构建在线表单原型供用户测试",
        "低保真界面原型验证交互逻辑"
      ]
    },
    {
      "term": "软件重用",
      "definition": "在新系统开发中复用已有组件、框架或代码以提高效率和质量。",
      "examples": [
        "使用开源支付组件",
        "复用权限管理模块"
      ]
    },
    {
      "term": "RFP",
      "definition": "请求提案（Request for Proposal），用于向供应商征集系统解决方案的正式文档。",
      "examples": [
        "发布RFP采购ERP系统",
        "RFP中明确性能与安全要求"
      ]
    },
    {
      "term": "参照完整性",
      "definition": "数据库中外键与主键之间的约束关系，确保数据一致性。",
      "examples": [
        "订单表中的客户ID必须存在于客户表中"
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "R1",
      "description": "系统边界必须清晰定义，所有输入输出必须通过边界进行，禁止系统内部直接访问外部环境。"
    },
    {
      "rule_id": "R2",
      "description": "DFD图必须满足平衡原则：上层数据流必须在下层被完整处理，不得出现‘黑洞’（数据消失）或‘奇迹’（数据无来源）。"
    },
    {
      "rule_id": "R3",
      "description": "每个DFD图的处理过程数量应遵循7±2原则，避免信息过载，确保可理解性。"
    },
    {
      "rule_id": "R4",
      "description": "事件必须是可描述、可记录、在特定时间和地点发生的业务触发点，技术错误（如输入错误）应被忽略，仅保留业务相关事件。"
    },
    {
      "rule_id": "R5",
      "description": "系统开发过程必须遵循阶段顺序：计划→分析→设计→开发→支持，计划阶段不可与其他阶段重叠。"
    },
    {
      "rule_id": "R6",
      "description": "版本更新属于演化过程中的维护阶段，不属于开发过程，开发过程仅包含分析、设计、实现与测试。"
    },
    {
      "rule_id": "R7",
      "description": "在面向对象设计中，类图中的属性与方法必须基于顺序图和状态图推导得出，确保行为与结构一致。"
    },
    {
      "rule_id": "R8",
      "description": "数据库设计必须为每个实体建立一张表，通过主键和外键建立关系，多对多关系必须通过关联表实现。"
    },
    {
      "rule_id": "R9",
      "description": "系统实施方案的选择必须综合评估通用需求、技术需求和功能需求三类标准，并加权计算得分后决策。"
    },
    {
      "rule_id": "R10",
      "description": "需求收集必须使用多种方法（调查表、访谈、观察、JAD、原型），避免单一方法导致需求偏差。"
    }
  ],
