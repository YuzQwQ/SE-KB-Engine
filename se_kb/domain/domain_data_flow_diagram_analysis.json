{
  "content_slug": "data_flow_diagram_analysis",
  "domain_id": "data_flow_diagram_analysis",
  "name": "数据流图需求分析",
  "description": "基于数据流图（DFD）进行系统需求分析的方法，用于清晰表达系统中数据的流动、处理和存储，支持业务流程建模与功能需求定义。",
  "terms": [
    {
      "term": "数据流图",
      "definition": "一种图形化技术，用于描述系统中数据的流动、处理、存储和外部实体之间的交互关系。",
      "examples": [
        "顶层数据流图",
        "0层数据流图",
        "一级数据流图"
      ]
    },
    {
      "term": "外部实体",
      "definition": "位于系统边界之外，与系统交互的人员、组织或其他系统，提供或接收数据。",
      "examples": [
        "客户",
        "供应商",
        "支付网关"
      ]
    },
    {
      "term": "处理过程",
      "definition": "系统中对数据进行转换、计算或操作的功能单元，通常用圆圈或椭圆表示。",
      "examples": [
        "订单处理",
        "用户认证",
        "库存更新"
      ]
    },
    {
      "term": "数据存储",
      "definition": "系统中用于持久化保存数据的逻辑存储单元，如数据库或文件。",
      "examples": [
        "用户表",
        "订单数据库",
        "日志文件"
      ]
    },
    {
      "term": "数据流",
      "definition": "表示数据在外部实体、处理过程和数据存储之间移动的箭头线，标明数据内容。",
      "examples": [
        "用户登录信息",
        "订单详情",
        "支付确认结果"
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "DFD-R01",
      "description": "每个处理过程必须有至少一个输入数据流和一个输出数据流，不允许孤立的处理节点。"
    },
    {
      "rule_id": "DFD-R02",
      "description": "数据流不能直接从外部实体流向数据存储，必须经过处理过程作为中介。"
    },
    {
      "rule_id": "DFD-R03",
      "description": "数据存储不能直接与其他数据存储相连，必须通过处理过程进行数据传递。"
    },
    {
      "rule_id": "DFD-R04",
      "description": "顶层数据流图应仅包含一个最高层处理过程，代表整个系统，以及所有外部实体和主要数据流。"
    },
    {
      "rule_id": "DFD-R05",
      "description": "数据流名称应使用名词短语，明确描述数据内容，避免使用动词或模糊表述。"
    }
  ],
  "models": [
    {
      "entity": "外部实体",
      "attributes": [
        "名称",
        "类型",
        "交互方式"
      ],
      "relationships": [
        "与数据流关联",
        "与处理过程交互"
      ]
    },
    {
      "entity": "处理过程",
      "attributes": [
        "编号",
        "名称",
        "功能描述",
        "输入数据流",
        "输出数据流"
      ],
      "relationships": [
        "接收数据流",
        "输出数据流",
        "访问数据存储"
      ]
    },
    {
      "entity": "数据存储",
      "attributes": [
        "名称",
        "类型",
        "存储内容",
        "访问频率"
      ],
      "relationships": [
        "被处理过程读取",
        "被处理过程写入"
      ]
    },
    {
      "entity": "数据流",
      "attributes": [
        "名称",
        "来源",
        "目标",
        "数据内容描述"
      ],
      "relationships": [
        "连接外部实体与处理过程",
        "连接处理过程与数据存储",
        "连接处理过程之间"
      ]
    }
  ],
