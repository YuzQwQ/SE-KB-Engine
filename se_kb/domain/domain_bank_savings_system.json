{
  "content_slug": "bank_savings_system",
  "domain_id": "bank_savings_system",
  "name": "银行储蓄系统",
  "description": "银行储蓄系统用于处理储户的存款与取款业务，通过数据流管理储户信息、存款记录和利息计算，实现自动化存取款服务。",
  "terms": [
    {
      "term": "存款单",
      "definition": "储户填写的用于申请存款的纸质单据，由业务员输入系统，包含姓名、住址、存款类型、存款日期、利率等信息。",
      "examples": [
        "储户张三填写的定期存款单",
        "活期存款申请表"
      ]
    },
    {
      "term": "取款单",
      "definition": "储户填写的用于申请取款的纸质单据，系统需验证账户余额并计算利息后生成利息清单。",
      "examples": [
        "储户李四提交的活期取款单",
        "定期存款到期取款申请"
      ]
    },
    {
      "term": "存款信息",
      "definition": "系统记录的电子化存款数据，包括储户姓名、住址、存款类型、存款日期、利率、余额等，用于后续取款和利息计算。",
      "examples": [
        "张三的5万元三年定期存款记录",
        "李四的2万元活期存款账户"
      ]
    },
    {
      "term": "利息清单",
      "definition": "系统根据取款请求和存款信息自动计算利息后生成的打印单据，列明本金、利率、利息金额和到账金额。",
      "examples": [
        "取款5000元，利息120元的结算单",
        "定期存款到期利息明细"
      ]
    },
    {
      "term": "数据流图",
      "definition": "用于描述系统中数据如何流动、处理和存储的图形化建模工具，包含数据源、处理过程、数据存储和数据终点。",
      "examples": [
        "银行储蓄系统的顶层数据流图",
        "存款与取款的分层数据流图"
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "R1",
      "description": "存款操作必须记录完整存款信息（姓名、住址、类型、日期、利率）并生成电子存款记录，同时打印纸质存款单交付储户。"
    },
    {
      "rule_id": "R2",
      "description": "取款操作必须先从存款信息文件中读取账户数据，验证存在有效存款后，方可计算利息并生成利息清单。"
    },
    {
      "rule_id": "R3",
      "description": "系统处理流程中，存款单与取款单必须作为独立数据流处理，不得合并或混淆处理逻辑。"
    },
    {
      "rule_id": "R4",
      "description": "数据流图设计中仅考虑合法数据流路径，不考虑验证失败、异常输入等边界情况。"
    },
    {
      "rule_id": "R5",
      "description": "系统实现细节（如字段存储方式）不应在数据流图中体现，仅关注数据流动与处理过程。"
    }
  ],
  "models": [
    {
      "entity": "储户",
      "attributes": [
        "姓名",
        "住址"
      ],
      "relationships": [
        "提交存款单",
        "提交取款单",
        "接收存款单",
        "接收利息清单"
      ]
    },
    {
