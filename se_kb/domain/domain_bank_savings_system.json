        "存款日期",
        "利率",
        "金额"
      ],
      "relationships": [
        "被输入系统",
        "生成存款信息",
        "打印为纸质凭证"
      ]
    },
    {
      "entity": "取款单",
      "attributes": [
        "取款金额",
