{
  "content_slug": "system_data_flow_analysis",
  "domain_id": "system_data_flow_analysis",
  "name": "系统数据流图分析",
  "description": "针对信息系统中数据流动的图形化建模与分析方法，用于理解业务流程、识别数据源与处理节点、优化系统架构。",
  "terms": [
    {
      "term": "数据流图",
      "definition": "一种图形化工具，用于描述系统中数据的流动、处理、存储和外部实体之间的交互关系。",
      "examples": [
        "上下文图",
        "0层图",
        "1层图"
      ]
    },
    {
      "term": "外部实体",
      "definition": "位于系统边界之外，与系统进行数据交互的人员、组织或其他系统。",
      "examples": [
        "客户",
        "供应商",
        "支付网关"
      ]
    },
    {
      "term": "处理过程",
      "definition": "系统中对数据进行转换、计算或操作的功能单元，通常用圆角矩形表示。",
      "examples": [
        "订单校验",
        "库存更新",
        "生成报表"
      ]
    },
    {
      "term": "数据存储",
      "definition": "系统中用于持久化保存数据的组件，如数据库或文件。",
      "examples": [
        "用户数据库",
        "订单历史表",
        "缓存文件"
      ]
    },
    {
      "term": "数据流",
      "definition": "表示数据在系统组件之间传递的有向箭头，标明数据内容和方向。",
      "examples": [
        "客户信息 → 订单处理",
        "库存数据 ← 库存更新"
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "DFD-001",
      "description": "每个处理过程必须至少有一个输入数据流和一个输出数据流，不允许孤立的处理节点。"
    },
    {
      "rule_id": "DFD-002",
      "description": "数据存储只能与处理过程相连，不能直接与外部实体交互。"
    },
    {
      "rule_id": "DFD-003",
      "description": "数据流必须有明确的名称，且不能是泛化的'数据'或'信息'，需体现具体业务含义。"
    },
    {
      "rule_id": "DFD-004",
      "description": "同一数据流在不同层级的图中必须保持语义一致性，不得在分解时改变其核心内容。"
    },
    {
      "rule_id": "DFD-005",
      "description": "外部实体不能直接相互传递数据，所有交互必须通过系统内部处理过程中转。"
    }
  ],
  "models": [
    {
      "entity": "外部实体",
      "attributes": [
        "名称",
        "类型",
        "交互方式"
      ],
      "relationships": [
        "与处理过程交互",
        "发送数据流",
        "接收数据流"
      ]
    },
    {
      "entity": "处理过程",
      "attributes": [
        "编号",
        "名称",
        "输入数据流",
        "输出数据流",
        "处理逻辑"
      ],
      "relationships": [
        "接收数据流",
        "产生数据流",
        "读取数据存储",
        "写入数据存储"
      ]
    },
    {
      "entity": "数据存储",
      "attributes": [
        "名称",
        "类型",
        "持久化方式",
        "访问频率"
      ],
      "relationships": [
        "被处理过程读取",
        "被处理过程写入"
      ]
    },
    {
      "entity": "数据流",
      "attributes": [
        "名称",
        "方向",
        "内容描述",
        "频率"
      ],
      "relationships": [
        "从外部实体到处理过程",
        "从处理过程到外部实体",
        "从处理过程到数据存储",
        "从数据存储到处理过程"
      ]
    }
  ],
