{
  "content_slug": "data_flow_diagram",
  "domain_id": "data_flow_diagram",
  "name": "数据流图",
  "description": "数据流图（Data Flow Diagram, DFD）是一种图形化技术，用于描述系统中数据的流动、处理、存储和与外部实体的交互，广泛应用于系统分析与软件工程领域。",
  "terms": [
    {
      "term": "数据流图 (Data Flow Diagram, DFD)",
      "definition": "一种图形化技术，用于展示系统中数据的流向、处理过程、存储位置以及与外部实体的交互关系。",
      "examples": [
        "使用飞书模板绘制的订单处理系统数据流图"
      ]
    },
    {
      "term": "数据流",
      "definition": "表示数据在系统组件之间移动的箭头，描述数据的传输方向。",
      "examples": [
        "用户输入 → 验证模块",
        "订单数据 → 数据库"
      ]
    },
    {
      "term": "处理过程",
      "definition": "对数据进行转换、计算或操作的逻辑单元，通常用圆角矩形表示。",
      "examples": [
        "验证用户身份",
        "计算订单总价",
        "生成发票"
      ]
    },
    {
      "term": "数据存储",
      "definition": "系统中用于持久化保存数据的组件，如数据库或文件，通常用两条平行线表示。",
      "examples": [
        "用户信息数据库",
        "订单历史文件",
        "缓存表"
      ]
    },
    {
      "term": "外部实体",
      "definition": "位于系统边界之外、与系统交互的人员、组织或系统，提供输入或接收输出。",
      "examples": [
        "客户",
        "支付网关",
        "管理员"
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "DFD_RULE_001",
      "description": "每个处理过程必须至少有一个输入数据流和一个输出数据流，禁止孤立的处理节点。"
    },
    {
      "rule_id": "DFD_RULE_002",
      "description": "数据流不能直接从外部实体流向数据存储，必须经过处理过程作为中介。"
    },
    {
      "rule_id": "DFD_RULE_003",
      "description": "数据存储只能通过处理过程读取或写入，不能直接与其他数据存储连接。"
    },
    {
      "rule_id": "DFD_RULE_004",
      "description": "数据流图必须明确界定系统边界，所有外部实体必须位于边界之外。"
    },
    {
      "rule_id": "DFD_RULE_005",
      "description": "同一层级的数据流图中，每个处理过程应具有唯一编号，避免命名冲突。"
    },
    {
      "rule_id": "DFD_RULE_006",
      "description": "数据流图应遵循分层设计原则，顶层图（0层）仅展示系统整体输入输出，子图（1层、2层）逐步细化处理过程。"
    }
  ],
  "models": [
