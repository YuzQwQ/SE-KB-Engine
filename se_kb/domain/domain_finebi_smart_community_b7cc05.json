{
  "content_slug": "smart_community",
  "domain_id": "smart_community",
  "name": "智慧社区系统",
  "description": "智慧社区系统通过数据流图实现物业、安防、访客、缴费、维修等模块的一体化流程管控，打通数据孤岛，推动数字化转型与自动化运营。",
  "terms": [
    {
      "term": "数据流图（DFD）",
      "definition": "一种图形化工具，用于展现数据在系统中的流动路径、处理节点和参与者交互关系，是信息系统分析与流程优化的核心方法。",
      "examples": [
        "访客登记流程中的数据流图",
        "报修工单流转的数据流图"
      ]
    },
    {
      "term": "外部实体",
      "definition": "位于系统边界之外、与系统交互的人员或系统，是数据的来源或接收方。",
      "examples": [
        "业主",
        "访客",
        "物业人员",
        "第三方门禁系统"
      ]
    },
    {
      "term": "数据流",
      "definition": "数据在系统内部或系统与外部实体之间流动的路径，表示信息的传递方向与内容。",
      "examples": [
        "业主APP提交报修单 → 物业平台",
        "门禁系统接收访客授权信息"
      ]
    },
    {
      "term": "处理过程",
      "definition": "对数据进行转换、计算或操作的节点，代表系统中的业务逻辑或功能模块。",
      "examples": [
        "访客信息审核",
        "报修工单自动派发",
        "缴费记录更新"
      ]
    },
    {
      "term": "数据存储",
      "definition": "系统中用于持久化保存数据的结构，如数据库、日志文件或数据仓库。",
      "examples": [
        "业主信息库",
        "设备运行日志",
        "缴费记录表"
      ]
    },
    {
      "term": "一体化流程管控",
      "definition": "通过数据流图实现社区各业务模块（如安防、物业、缴费）的数据互通与流程协同，达成自动化、可追溯、可监控的统一管理。",
      "examples": [
        "访客登记自动联动门禁授权",
        "报修工单自动推送并反馈闭环"
      ]
    },
    {
      "term": "数据孤岛",
      "definition": "不同系统间因接口不互通、标准不统一而导致的数据无法共享与联动的现象。",
      "examples": [
        "门禁系统与物业系统数据独立存储",
        "缴费平台与安防告警系统无数据交互"
      ]
    },
    {
      "term": "自助式商业智能（BI）工具",
      "definition": "支持非技术人员通过拖拽操作进行数据接入、建模、可视化分析与报表生成的数字化平台。",
      "examples": [
        "FineBI",
        "Tableau",
        "Power BI"
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "R001",
      "description": "数据流图绘制必须由业务人员与技术人员共同参与，确保图示真实反映业务逻辑，避免技术导向脱离实际需求。"
    },
    {
      "rule_id": "R002",
      "description": "每个数据流必须有明确的起点（外部实体或处理过程）、终点（处理过程或数据存储）和内容定义，禁止出现无源或无汇的数据流。"
    },
    {
      "rule_id": "R003",
      "description": "数据流图需分层绘制（0层总览、1层业务模块、2层细节节点），避免单图信息过载，确保可读性与可维护性。"
    },
    {
      "rule_id": "R004",
      "description": "所有关键业务流程（如访客登记、报修处理、缴费提醒）必须实现数据闭环，即数据从发起、处理到反馈的完整路径可追溯。"
    },
    {
      "rule_id": "R005",
      "description": "数据流图需定期复盘（每季度或流程变更后），确保与实际运营流程同步，防止图实脱节导致管控失效。"
    },
    {
      "rule_id": "R006",
      "description": "多系统联动必须通过统一数据平台或中台实现接口整合，禁止点对点直连，以保障扩展性与数据一致性。"
    },
    {
      "rule_id": "R007",
      "description": "流程自动化必须基于明确的数据流规则触发，如访客信息通过审核后自动授权门禁，禁止人工干预关键节点。"
    },
    {
      "rule_id": "R008",
      "description": "数据权限必须按角色配置，确保业主隐私数据（如房号、联系方式）仅限授权人员访问，符合数据安全规范。"
    },
    {
      "rule_id": "R009",
      "description": "流程异常（如维修超时、访客未核验）必须自动触发告警或升级机制，并记录在数据流图中作为处理节点。"
    },
    {
      "rule_id": "R010",
      "description": "数据流图应作为社区管理标准文档纳入知识库，所有流程变更必须同步更新图示并通知相关方。"
    }
  ],
  "models": [
    {
      "entity": "业主",
      "attributes": [
        "姓名",
        "房号",
        "联系方式",
        "权限等级"
      ],
      "relationships": [
        "发起访客邀约",
        "提交报修工单",
        "缴纳物业费用",
        "接收服务反馈"
      ]
    },
    {
      "entity": "访客",
      "attributes": [
