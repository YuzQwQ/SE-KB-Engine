        "访问权限"
      ],
      "relationships": [
        "存储业主信息",
        "存储设备日志",
        "存储工单历史",
        "供BI工具分析"
      ]
    },
    {
      "entity": "BI分析平台",
      "attributes": [
        "数据源接入能力",
        "可视化看板",
        "权限控制等级",
        "预警规则"
      ],
      "relationships": [
        "整合多系统数据",
        "生成运营报表",
        "推送异常预警",
        "支持自助分析"
      ]
    }
  ]
}