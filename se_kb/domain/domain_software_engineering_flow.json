{
  "content_slug": "software_engineering_flow",
  "domain_id": "software_engineering_flow",
  "name": "软件工程流程图与数据流图分析",
  "description": "软件工程中用于描述系统数据流动和处理过程的图形化分析方法，包括数据流图（DFD）和流程图的绘制规范与分析技巧。",
  "terms": [
    {
      "term": "数据流图（DFD）",
      "definition": "一种图形化技术，用于表示系统中数据的流动、处理、存储和外部实体之间的交互关系。",
      "examples": [
        "0层DFD（上下文图）",
        "一级DFD（分解图）",
        "数据存储（Data Store）"
      ]
    },
    {
      "term": "加工（Process）",
      "definition": "数据流图中表示对数据进行转换或处理的逻辑单元，通常用圆圈或矩形表示。",
      "examples": [
        "验证用户登录",
        "生成销售报表"
      ]
    },
    {
      "term": "外部实体",
      "definition": "位于系统边界之外、与系统交互的人员、组织或系统，是数据的来源或去向。",
      "examples": [
        "客户",
        "支付网关",
        "管理员"
      ]
    },
    {
      "term": "数据流",
      "definition": "表示数据在系统组件之间移动的箭头线，标注数据内容或类型。",
      "examples": [
        "用户输入→登录验证",
        "订单数据→库存系统"
      ]
    },
    {
      "term": "流程图",
      "definition": "用标准符号表示程序或业务流程中各步骤的顺序和逻辑关系的图形工具。",
      "examples": [
        "开始/结束框",
        "判断框（菱形）",
        "处理框（矩形）"
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "rule_001",
      "description": "数据流图中每个加工必须有至少一个输入数据流和一个输出数据流，禁止孤立加工。"
    },
    {
      "rule_id": "rule_002",
      "description": "数据存储不能直接与外部实体相连，必须通过加工作为中介。"
    },
    {
      "rule_id": "rule_003",
      "description": "同一数据流在不同层级的DFD中必须保持名称和内容一致性，避免语义漂移。"
    },
    {
      "rule_id": "rule_004",
      "description": "流程图中的每个判断节点必须有且仅有两个出口，分别对应真/假或是/否。"
    },
    {
      "rule_id": "rule_005",
      "description": "数据流图应避免出现交叉线条，保持清晰可读，必要时使用编号或分层分解。"
    }
  ],
  "models": [
