{
  "description": "用于从需求文本中识别 DFD 元素的语义性策略和启发式，不进行强制式关键词映射。",
  "version": "0.1",
  "strategies": {
    "process_identification": {
      "criteria": [
        "描述对输入进行转换、处理、判断、控制、计算的动作通常对应 Process。",
        "动词短语（如“验证密码”“处理订单”“计算金额”）往往表示潜在的处理逻辑。",
        "若句子描述了由多个步骤组成的业务活动，则拆分成子 Process。"
      ],
      "signals": [
        "包含动作动词：验证、处理、更新、生成、检查、记录、计算。",
        "描述数据的转换：A 转成 B、解析、格式化。",
        "含控制流含义：“如果…则…”、“根据…决定…”。"
      ]
    },
    "external_entity_identification": {
      "criteria": [
        "不是系统内部的一部分，但与系统交换信息的角色或系统。",
        "数据的发起者或接收者，是数据流的端点。",
        "可为用户、第三方平台、设备、上级系统。"
      ],
      "signals": [
        "描述为系统外部参与方：用户、管理员、客户端、供应商。",
        "动作是：提交、输入、接收、请求。",
        "在业务叙述中承担主动发起的角色。"
      ]
    },
    "data_store_identification": {
      "criteria": [
        "描述持久保存、长期存在的数据集合。",
        "表示为“某信息长期保存在系统中”的对象。",
        "具有明确的实体结构（如账户表、库存记录、档案）。"
      ],
      "signals": [
        "含关键词：数据库、记录、档案、清单、账本、库存。",
        "描述持久化行为：保存、存储、写入、更新记录。",
        "需求中以名词集合形式出现：账户信息、库存表、订单列表。"
      ]
    },
    "data_flow_identification": {
      "criteria": [
        "描述信息从一个参与者/过程流向另一个参与者/过程。",
        "通常为名词性数据，例如：卡号、余额、请求包、错误信息。",
        "文本中出现“系统传给… / 接收…”描述的数据内容。"
      ],
      "signals": [
        "动词：传送、返回、推送、提交。",
        "典型名词：请求、响应、消息、数据包、参数。",
        "用于触发某个过程或被过程输出。"
      ]
    }
  }
  ,
  "scoring": {
    "aggregation": "weighted_sum",
    "weights": {
      "process": {"verb": 0.4, "data_transform": 0.3, "control_flow": 0.3},
      "external_entity": {"role_keyword": 0.5, "request_action": 0.3, "outside_boundary": 0.2},
      "data_store": {"persistence_keyword": 0.5, "record_structure": 0.3, "noun_collection": 0.2},
      "data_flow": {"transfer_verb": 0.4, "data_noun": 0.4, "trigger_relation": 0.2}
    }
  },
  "thresholds": {
    "process": 0.6,
    "external_entity": 0.6,
    "data_store": 0.6,
    "data_flow": 0.6
  },
  "negative_signals": {
    "forbid": ["不允许", "不得", "禁止"],
    "exception": ["错误", "失败", "异常"],
    "timeout": ["超时", "等待超时"]
  },
  "conflict_resolution": {
    "rules": [
      "若同时匹配 external_entity 与 process，优先 external_entity，当文本为现实角色且不含内部处理逻辑",
      "若同时匹配 data_store 与 process，优先 data_store，当出现持久化关键词且描述为名词集合",
      "若两类分值接近（差值 < 0.1），保留为建议，标注需要人工确认"
    ]
  },
  "template_recommendations": {
    "conditional": {"pattern": "(如果|若|当).*(则|那么)", "template_id": "conditional_dispatch"},
    "error": {"pattern": "(错误|失败|异常)", "template_id": "error_branch"},
    "timeout": {"pattern": "(超时|等待超时)", "template_id": "timeout_handling"}
  },
  "trace_fields": ["rule_id", "matched_text", "signals", "score", "suggestion"],
  "examples": [
    {
      "text": "系统验证用户密码，失败则提示错误。",
      "signals": {"process": ["验证"], "conditional": ["失败则"], "error": ["错误"]},
      "suggestions": [
        {"type": "process", "name_template": "验证密码", "score": 0.82},
        {"type": "template_ref", "template_id": "error_branch", "score": 0.75}
      ]
    },
    {
      "text": "订单信息保存到数据库，用户可查询历史订单。",
      "signals": {"data_store": ["数据库", "订单"], "process": ["保存"], "data_flow": ["查询"]},
      "suggestions": [
        {"type": "data_store", "name_template": "订单库", "score": 0.86},
        {"type": "process", "name_template": "保存订单", "score": 0.74},
        {"type": "process", "name_template": "查询订单", "score": 0.72}
      ]
    }
  ]
}
