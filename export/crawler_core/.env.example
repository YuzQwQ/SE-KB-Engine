#############################################
# Crawler Core 环境变量示例 (.env.example)
# 将本文件复制为 .env 并填入你的真实值
#############################################

# 选择视觉模型提供方（仅在 --images 时使用）
# 可选：siliconflow 或 http
VISUAL_MODEL_PROVIDER=siliconflow

#############################################
# SiliconFlow 适配器示例配置
# 仅当 VISUAL_MODEL_PROVIDER=siliconflow 生效
#############################################
VISUAL_MODEL_BASE_URL=https://api.siliconflow.cn/v1
VISUAL_MODEL_API_KEY=sk-your-siliconflow-key
VISUAL_MODEL=Qwen2.5-VL-7B-Instruct
VISUAL_MODEL_TIMEOUT=60

#############################################
# 通用 HTTP 适配器示例配置
# 仅当 VISUAL_MODEL_PROVIDER=http 生效
#############################################
VISUAL_MODEL_ENDPOINT=https://your-vision-api.example.com/infer
VISUAL_MODEL_API_KEY=token-xxxx
VISUAL_MODEL_TIMEOUT=30
# 请求字段映射（根据你的远端接口实际调整）
VISUAL_MODEL_REQ_URL_FIELD=image_url
VISUAL_MODEL_REQ_B64_FIELD=image_base64
VISUAL_MODEL_REQ_TASKS_FIELD=tasks
# 响应字段映射（根据你的远端接口实际调整）
VISUAL_MODEL_RESP_OCR_FIELD=ocr
VISUAL_MODEL_RESP_DESCRIPTION_FIELD=description
VISUAL_MODEL_RESP_DFD_FIELD=dfd

#############################################
# 人类行为模拟（低成本）
#############################################
# Playwright 动态渲染的人类行为模拟（默认开启；设为 0/false 关闭）
PLAYWRIGHT_HUMAN_SIM=1
# 人类停留时间下限/上限（秒），仅在 PLAYWRIGHT_HUMAN_SIM=1 时生效
HUMAN_SIM_MIN_DWELL_SEC=7
HUMAN_SIM_MAX_DWELL_SEC=12

# httpx 静态抓取的随机 UA 与语言（默认开启；设为 0/false 关闭）
HTTPX_RANDOM_UA=1

#############################################
# 代理池（可选）
#############################################
# 启用代理池（设为 1/true 开启；默认关闭）
PROXY_POOL_ENABLED=0
# 代理池文件路径（相对 export/crawler_core/ 或绝对路径）
PROXY_POOL_FILE=config/proxies.txt
# 或者仅使用单一代理（设置该值将覆盖文件）
# 支持格式：http://host:port、http://user:pass@host:port、socks5://host:port
PROXY_URL=
# 是否每次静态请求都轮换代理（默认 1），设为 0 则固定会话内的代理
PROXY_ROTATE_PER_REQUEST=1