{
  "universal_knowledge_base": {
    "name": "通用知识库格式",
    "description": "支持需求转换的生成和验证的通用知识库结构",
    "version": "1.0.0",
    "json_structure": {
      "metadata": {
        "knowledge_id": "string",
        "title": "string",
        "description": "string",
        "version": "string",
        "created_time": "datetime",
        "updated_time": "datetime",
        "source_info": {
          "source_url": "string",
          "source_type": "string",
          "crawl_time": "datetime",
          "extraction_method": "string",
          "reliability_score": "float"
        }
      },
      "requirement_type": "string",
      "target_conversion_type": "string",
      "generation_knowledge": {
        "concepts": {
          "description": "核心概念和定义",
          "fields": {
            "concept_id": "string",
            "name": "简洁的主题短语（15-30字符，概括核心主题）",
            "definition": "完整的概念定义和详细解释，包含上下文和专业描述",
            "category": "string",
            "attributes": "object",
            "relationships": "array"
          }
        },
        "rules": {
          "description": "生成规则和约束",
          "fields": {
            "rule_id": "string",
            "type": "string",
            "condition": "string",
            "action": "string",
            "priority": "integer",
            "applicable_scenarios": "array"
          }
        },
        "patterns": {
          "description": "常用模式和模板",
          "fields": {
            "pattern_id": "string",
            "name": "string",
            "template": "string",
            "variables": "object",
            "usage_context": "string",
            "complexity_level": "string"
          }
        },
        "transformations": {
          "description": "转换方法和步骤",
          "fields": {
            "transformation_id": "string",
            "from_format": "string",
            "to_format": "string",
            "steps": "array",
            "tools_required": "array",
            "preconditions": "array"
          }
        }
      },
      "validation_knowledge": {
        "criteria": {
          "description": "验证标准和指标",
          "fields": {
            "criteria_id": "string",
            "name": "string",
            "description": "string",
            "measurement_method": "string",
            "threshold_values": "object",
            "weight": "float"
          }
        },
        "checklist": {
          "description": "检查清单和验证点",
          "fields": {
            "check_id": "string",
            "category": "string",
            "description": "string",
            "validation_method": "string",
            "expected_result": "string",
            "severity_level": "string"
          }
        },
        "error_patterns": {
          "description": "常见错误模式和解决方案",
          "fields": {
            "error_id": "string",
            "pattern_description": "string",
            "symptoms": "array",
            "root_causes": "array",
            "solutions": "array",
            "prevention_measures": "array"
          }
        }
      },
      "examples": {
        "input_examples": {
          "description": "输入示例集合",
          "fields": {
            "example_id": "string",
            "title": "string",
            "content": "string",
            "format": "string",
            "complexity_level": "string",
            "tags": "array"
          }
        },
        "output_examples": {
          "description": "输出示例集合",
          "fields": {
            "example_id": "string",
            "input_reference": "string",
            "content": "string",
            "format": "string",
            "quality_score": "float",
            "annotations": "object"
          }
        },
        "transformation_examples": {
          "description": "转换过程示例",
          "fields": {
            "example_id": "string",
            "input_example_id": "string",
            "output_example_id": "string",
            "transformation_steps": "array",
            "intermediate_results": "array",
            "notes": "string"
          }
        }
      },
      "relationships": {
        "related_knowledge_bases": "array",
        "dependency_graph": "object",
        "cross_references": "array"
      }
    },
    "extraction_config": {
      "concepts": {
        "max_count": 15,
        "min_confidence": 0.7,
        "diversification_strategy": "semantic_variation",
        "patterns": {
          "definition_indicators": ["定义", "概念", "是指", "指的是", "表示", "所谓", "即", "称为"],
          "category_indicators": ["类型", "种类", "分类", "类别", "分为", "包括"],
          "attribute_indicators": ["属性", "特征", "特点", "性质", "特性"]
        },
        "semantic_filters": {
          "min_length": 20,
          "max_length": 500,
          "forbidden_patterns": ["^\\d+[\\.\\s]", "^第[一二三四五六七八九十]+章", "^[A-Z]\\.[\\s]"],
          "required_keywords": ["是", "指", "为", "表示"]
        }
      },
      "rules": {
        "max_count": 12,
        "min_confidence": 0.6,
        "diversification_strategy": "condition_action_variation",
        "patterns": {
          "rule_indicators": ["规则", "约束", "限制", "要求", "必须", "应该", "应当", "需要"],
          "condition_indicators": ["如果", "当", "在...情况下", "条件", "假设", "若"],
          "action_indicators": ["则", "那么", "执行", "进行", "操作", "应用", "使用"]
        },
        "complexity_levels": ["basic", "intermediate", "advanced"],
        "validation_criteria": {
          "min_condition_length": 10,
          "min_action_length": 15,
          "max_total_length": 300
        }
      },
      "patterns": {
        "max_count": 10,
        "min_confidence": 0.65,
        "diversification_strategy": "template_structure_variation",
        "patterns": {
          "template_indicators": ["模板", "模式", "范式", "样式", "格式", "结构", "框架"],
          "usage_indicators": ["使用", "应用", "适用于", "场景", "情况", "环境"]
        },
        "template_variations": ["structural", "behavioral", "creational", "architectural"],
        "validation_rules": {
          "min_template_elements": 2,
          "max_template_complexity": 5,
          "required_placeholders": true
        }
      },
      "transformations": {
        "max_count": 8,
        "min_confidence": 0.7,
        "diversification_strategy": "step_complexity_variation",
        "patterns": {
          "step_indicators": ["步骤", "阶段", "过程", "流程", "顺序"],
          "method_indicators": ["方法", "技术", "工具", "手段", "方式"]
        },
        "step_complexity": ["simple", "moderate", "complex"],
        "validation_requirements": {
          "min_step_count": 2,
          "max_step_count": 15,
          "required_tools": true,
          "precondition_completeness": 0.8
        }
      },
      "validation": {
        "criteria_indicators": ["标准", "指标", "准则", "要求", "规范"],
        "error_indicators": ["错误", "问题", "缺陷", "异常", "故障", "失败"],
        "quality_thresholds": {
          "min_reliability_score": 0.75,
          "max_similarity_threshold": 0.85,
          "min_content_diversity": 0.6
        }
      }
    }
  }
}